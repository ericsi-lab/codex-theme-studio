#!/bin/sh
set -eu

PLUGIN_DIR=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
if [ -n "${CTS_NODE:-}" ]; then
  NODE=$CTS_NODE
elif command -v node >/dev/null 2>&1 && [ "$(node -p 'Number(process.versions.node.split(`.`)[0]) >= 22' 2>/dev/null || true)" = "true" ]; then
  NODE=$(command -v node)
elif [ -x "$HOME/.cache/codex-runtimes/codex-primary-runtime/dependencies/node/bin/node" ]; then
  NODE="$HOME/.cache/codex-runtimes/codex-primary-runtime/dependencies/node/bin/node"
else
  echo '{"ok":false,"code":"NODE_UNAVAILABLE","message":"Node.js 22 or newer is required."}' >&2
  exit 1
fi

exec "$NODE" "$PLUGIN_DIR/runtime/src/cli.mjs" "$@"

